<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- High Contrast Color Palette -->
    <SolidColorBrush x:Key="HighContrast.Background" Color="#000000"/>
    <SolidColorBrush x:Key="HighContrast.Foreground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrast.AccentBackground" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HighContrast.AccentForeground" Color="#000000"/>
    <SolidColorBrush x:Key="HighContrast.BorderBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrast.ButtonBackground" Color="#808080"/>
    <SolidColorBrush x:Key="HighContrast.ButtonForeground" Color="#000000"/>
    <SolidColorBrush x:Key="HighContrast.ButtonHover" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrast.ButtonPressed" Color="#C0C0C0"/>
    <SolidColorBrush x:Key="HighContrast.TextBoxBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrast.TextBoxForeground" Color="#000000"/>
    <SolidColorBrush x:Key="HighContrast.SuccessColor" Color="#00FF00"/>
    <SolidColorBrush x:Key="HighContrast.WarningColor" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HighContrast.ErrorColor" Color="#FF0000"/>
    <SolidColorBrush x:Key="HighContrast.InfoColor" Color="#00FFFF"/>

    <!-- Window Style -->
    <Style x:Key="HighContrastWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource HighContrast.Background}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.Foreground}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Button Style -->
    <Style x:Key="HighContrastButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HighContrast.ButtonBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.ButtonForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource HighContrast.ButtonHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource HighContrast.Background}"/>
                            <Setter Property="BorderThickness" Value="3"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource HighContrast.ButtonPressed}"/>
                            <Setter Property="Foreground" Value="{StaticResource HighContrast.Background}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#404040"/>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Setter Property="BorderBrush" Value="#808080"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderThickness" Value="4"/>
                            <Setter Property="BorderBrush" Value="{StaticResource HighContrast.AccentBackground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox Style -->
    <Style x:Key="HighContrastTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource HighContrast.TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.TextBoxForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                    Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderThickness" Value="3"/>
                            <Setter Property="BorderBrush" Value="{StaticResource HighContrast.AccentBackground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#404040"/>
                            <Setter Property="Foreground" Value="#808080"/>
                            <Setter Property="BorderBrush" Value="#808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Label Style -->
    <Style x:Key="HighContrastLabelStyle" TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.Foreground}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- TextBlock Style -->
    <Style x:Key="HighContrastTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.Foreground}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <!-- DataGrid Style -->
    <Style x:Key="HighContrastDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource HighContrast.Background}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.Foreground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="RowBackground" Value="{StaticResource HighContrast.Background}"/>
        <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>

    <!-- DataGridColumnHeader Style -->
    <Style x:Key="HighContrastDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HighContrast.ButtonBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.ButtonForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <!-- DataGridRow Style -->
    <Style x:Key="HighContrastDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource HighContrast.Background}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource HighContrast.AccentBackground}"/>
                <Setter Property="Foreground" Value="{StaticResource HighContrast.AccentForeground}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#333333"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox Style -->
    <Style x:Key="HighContrastComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource HighContrast.TextBoxBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource HighContrast.TextBoxForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <!-- CheckBox Style -->
    <Style x:Key="HighContrastCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.Foreground}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="CheckBoxBorder"
                                Width="20"
                                Height="20"
                                Background="{StaticResource HighContrast.TextBoxBackground}"
                                BorderBrush="{StaticResource HighContrast.BorderBrush}"
                                BorderThickness="2"
                                Margin="0,0,8,0">
                            <TextBlock x:Name="CheckMark"
                                     Text="✓"
                                     Foreground="{StaticResource HighContrast.TextBoxForeground}"
                                     FontSize="14"
                                     FontWeight="Bold"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="Hidden"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="CheckBoxBorder" Property="BorderThickness" Value="3"/>
                            <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource HighContrast.AccentBackground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CheckBoxBorder" Property="Background" Value="#404040"/>
                            <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#808080"/>
                            <Setter Property="Foreground" Value="#808080"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Border Style -->
    <Style x:Key="HighContrastBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HighContrast.Background}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HighContrast.BorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Status Colors -->
    <Style x:Key="HighContrastSuccessTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HighContrastTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.SuccessColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="HighContrastWarningTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HighContrastTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.WarningColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="HighContrastErrorTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HighContrastTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.ErrorColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="HighContrastInfoTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HighContrastTextBlockStyle}">
        <Setter Property="Foreground" Value="{StaticResource HighContrast.InfoColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>