<Window x:Class="VrcGroupGuardian.Views.SetupWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VRC Group Guardian - First Run Setup" 
        Height="600" 
        Width="800"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="WizardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>
        
        <Style x:Key="StepHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <Style x:Key="StepDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>
        
        <Style x:Key="WizardButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="InputLabelStyle" TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Padding="30,20">
            <StackPanel>
                <TextBlock Text="Welcome to VRC Group Guardian" Style="{StaticResource WizardHeaderStyle}"/>
                <TextBlock Text="Let's get you set up to manage your VRChat groups effectively" 
                         FontSize="14" 
                         Foreground="#666" 
                         HorizontalAlignment="Center"/>
                
                <!-- Progress Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Border Width="30" Height="30" CornerRadius="15" 
                            Background="{Binding Step1Background}" 
                            BorderBrush="#2196F3" 
                            BorderThickness="2" 
                            Margin="5">
                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                 Foreground="{Binding Step1Foreground}" FontWeight="Bold"/>
                    </Border>
                    <Rectangle Width="50" Height="2" Fill="#E0E0E0" VerticalAlignment="Center"/>
                    <Border Width="30" Height="30" CornerRadius="15" 
                            Background="{Binding Step2Background}" 
                            BorderBrush="#2196F3" 
                            BorderThickness="2" 
                            Margin="5">
                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                 Foreground="{Binding Step2Foreground}" FontWeight="Bold"/>
                    </Border>
                    <Rectangle Width="50" Height="2" Fill="#E0E0E0" VerticalAlignment="Center"/>
                    <Border Width="30" Height="30" CornerRadius="15" 
                            Background="{Binding Step3Background}" 
                            BorderBrush="#2196F3" 
                            BorderThickness="2" 
                            Margin="5">
                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                 Foreground="{Binding Step3Foreground}" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                
                <TextBlock Text="{Binding CurrentStepDescription}" 
                         FontSize="12" 
                         Foreground="#666" 
                         HorizontalAlignment="Center" 
                         Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="40,30">
            <StackPanel>
            
            <!-- Step 1: Authentication -->
            <StackPanel x:Name="Step1Panel" Visibility="{Binding Step1Visibility}">
                <TextBlock Text="🔐 Authentication Setup" Style="{StaticResource StepHeaderStyle}"/>
                <TextBlock Style="{StaticResource StepDescriptionStyle}">
                    VRC Group Guardian needs to authenticate with VRChat to monitor and manage your groups. 
                    Please provide your VRChat credentials. These will be securely stored using Windows Credential Manager.
                </TextBlock>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="VRChat Username or Email:" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputTextBoxStyle}"/>
                        
                        <Label Content="Password:" Style="{StaticResource InputLabelStyle}"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPasswordBoxStyle}"/>
                        
                        <Label Content="2FA Code (if enabled):" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Text="{Binding TwoFactorCode, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 MaxLength="6"
                                 Width="100"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Border Background="#E3F2FD" BorderBrush="#2196F3" BorderThickness="1" 
                                CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="🔒 Security Information" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#555">
                                    • Your credentials are encrypted using Windows DPAPI<LineBreak/>
                                    • Passwords are never stored in plain text<LineBreak/>
                                    • Only you can decrypt your stored credentials<LineBreak/>
                                    • Authentication tokens automatically expire for security
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                        <Button Content="Test Connection" 
                                Command="{Binding TestConnectionCommand}"
                                Style="{StaticResource WizardButtonStyle}"
                                Background="#17A2B8"
                                Foreground="White"
                                HorizontalAlignment="Left"/>
                        
                        <TextBlock Text="{Binding AuthenticationStatus}" 
                                 Margin="0,10,0,0"
                                 Foreground="{Binding AuthenticationStatusColor}"
                                 FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
            <!-- Step 2: Group Selection -->
            <StackPanel x:Name="Step2Panel" Visibility="{Binding Step2Visibility}">
                <TextBlock Text="👥 Group Selection" Style="{StaticResource StepHeaderStyle}"/>
                <TextBlock Style="{StaticResource StepDescriptionStyle}">
                    Select the VRChat group you want to manage. VRC Group Guardian will monitor and enforce 
                    policies for instances created by this group.
                </TextBlock>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Available Groups:" Style="{StaticResource InputLabelStyle}"/>
                        <ListBox ItemsSource="{Binding AvailableGroups}"
                                SelectedItem="{Binding SelectedGroup}"
                                Height="200"
                                Margin="0,0,0,15">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding MemberCount, StringFormat=' ({0} members)'}" 
                                                 Foreground="#666" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Button Content="Refresh Groups" 
                                Command="{Binding RefreshGroupsCommand}"
                                Style="{StaticResource WizardButtonStyle}"
                                Background="#6C757D"
                                Foreground="White"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Border Background="#FFF3CD" BorderBrush="#FFEAA7" BorderThickness="1" 
                                CornerRadius="4" Padding="15" Margin="0,0,0,15"
                                Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Selected Group Details" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Name: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedGroup.GroupName}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Members: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedGroup.MemberCount}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Your Role: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SelectedGroup.UserRole}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedGroup.Description}" 
                                         TextWrapping="Wrap" 
                                         FontSize="11" 
                                         Foreground="#555" 
                                         Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#F8D7DA" BorderBrush="#F5C6CB" BorderThickness="1" 
                                CornerRadius="4" Padding="15"
                                Visibility="{Binding HasInsufficientPermissions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="⚠️ Permission Warning" FontWeight="Bold" Foreground="#721C24" Margin="0,0,0,5"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#721C24">
                                    You need Owner or Moderator permissions to manage group instances. 
                                    Contact your group owner to upgrade your role.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
            <!-- Step 3: Configuration -->
            <StackPanel x:Name="Step3Panel" Visibility="{Binding Step3Visibility}">
                <TextBlock Text="⚙️ Policy Configuration" Style="{StaticResource StepHeaderStyle}"/>
                <TextBlock Style="{StaticResource StepDescriptionStyle}">
                    Configure how VRC Group Guardian should monitor and manage your group instances. 
                    These settings can be changed later in the application.
                </TextBlock>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <Label Content="Grace Period (seconds):" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Text="{Binding GracePeriodSeconds, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"/>
                        <TextBlock Text="Time before automatically closing instances" 
                                 FontSize="10" Foreground="#666" Margin="0,-10,0,15"/>
                        
                        <Label Content="Polling Interval (seconds):" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Text="{Binding PollingIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"/>
                        <TextBlock Text="How often to check for new instances" 
                                 FontSize="10" Foreground="#666" Margin="0,-10,0,15"/>
                        
                        <Label Content="Rate Limit (requests/minute):" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox Text="{Binding RateLimitRequestsPerMinute, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Width="100" HorizontalAlignment="Left"/>
                        <TextBlock Text="API request limit to avoid throttling" 
                                 FontSize="10" Foreground="#666" Margin="0,-10,0,15"/>
                        
                        <CheckBox Content="Enable Desktop Notifications" 
                                  IsChecked="{Binding NotificationsEnabled}" 
                                  Margin="0,10,0,5"/>
                        <CheckBox Content="Export Audit Logs Automatically" 
                                  IsChecked="{Binding ExportAuditLogs}" 
                                  Margin="0,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <Border Background="#D4EDDA" BorderBrush="#C3E6CB" BorderThickness="1" 
                                CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📋 Recommended Settings" FontWeight="Bold" Foreground="#155724" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Grace Period: " FontWeight="SemiBold" Foreground="#155724"/>
                                    <TextBlock Text="300 seconds (5 minutes)" Foreground="#155724"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Polling Interval: " FontWeight="SemiBold" Foreground="#155724"/>
                                    <TextBlock Text="60 seconds" Foreground="#155724"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Rate Limit: " FontWeight="SemiBold" Foreground="#155724"/>
                                    <TextBlock Text="20 requests/minute" Foreground="#155724"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#155724">
                                    These settings balance effectiveness with VRChat's API limits and provide 
                                    a good user experience.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                        <Button Content="Use Recommended Settings" 
                                Command="{Binding UseRecommendedSettingsCommand}"
                                Style="{StaticResource WizardButtonStyle}"
                                Background="#28A745"
                                Foreground="White"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
            
            </StackPanel>
        </ScrollViewer>
        
        <!-- Navigation Buttons -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           VerticalAlignment="Center"
                           Foreground="#666"/>
                
                <Button Grid.Column="1" 
                        Content="Previous" 
                        Command="{Binding PreviousStepCommand}"
                        Style="{StaticResource WizardButtonStyle}"
                        Background="#6C757D"
                        Foreground="White"
                        IsEnabled="{Binding CanGoBack}"/>
                
                <Button Grid.Column="2" 
                        Content="{Binding NextButtonText}" 
                        Command="{Binding NextStepCommand}"
                        Style="{StaticResource WizardButtonStyle}"
                        Background="#007BFF"
                        Foreground="White"
                        IsEnabled="{Binding CanGoNext}"/>
                
                <Button Grid.Column="3" 
                        Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource WizardButtonStyle}"
                        Background="Transparent"
                        BorderBrush="#6C757D"
                        BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</Window>