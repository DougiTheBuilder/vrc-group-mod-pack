<Window x:Class="VrcGroupGuardian.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VRC Group Guardian" 
        Height="800" 
        Width="1200"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style x:Key="NavigationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ActiveNavigationButtonStyle" TargetType="Button" BasedOn="{StaticResource NavigationButtonStyle}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Navigation Panel -->
        <Border Grid.Column="0" 
                Background="#F5F5F5" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Border Grid.Row="0" 
                        Background="#2196F3" 
                        Padding="16,20">
                    <StackPanel>
                        <TextBlock Text="VRC Group Guardian" 
                                 FontSize="16" 
                                 FontWeight="Bold" 
                                 Foreground="White"
                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentGroupName, FallbackValue='No Group Selected'}" 
                                 FontSize="12" 
                                 Foreground="#E3F2FD"
                                 HorizontalAlignment="Center"
                                 Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Navigation Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10">
                        
                        <Button Content="🏠 Instances" 
                                Style="{StaticResource NavigationButtonStyle}"
                                Command="{Binding NavigateToInstancesCommand}"
                                x:Name="InstancesNavButton"/>
                        
                        <Button Content="👥 Members" 
                                Style="{StaticResource NavigationButtonStyle}"
                                Command="{Binding NavigateToMembersCommand}"
                                x:Name="MembersNavButton"/>
                        
                        <Button Content="📊 Audit Trail" 
                                Style="{StaticResource NavigationButtonStyle}"
                                Command="{Binding NavigateToAuditCommand}"
                                x:Name="AuditNavButton"/>
                        
                        <Button Content="⚙️ Settings" 
                                Style="{StaticResource NavigationButtonStyle}"
                                Command="{Binding NavigateToSettingsCommand}"
                                x:Name="SettingsNavButton"/>
                        
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Status Bar -->
                <Border Grid.Row="2" 
                        Background="#FAFAFA" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Authentication Status -->
                        <StackPanel Grid.Row="0" 
                                  Orientation="Horizontal" 
                                  Margin="0,0,0,5">
                            <Ellipse Style="{StaticResource StatusIndicatorStyle}"
                                   Fill="{Binding IsAuthenticated, Converter={StaticResource BoolToStatusColorConverter}, FallbackValue=Red}"/>
                            <TextBlock Text="{Binding AuthenticationStatus, FallbackValue='Not Authenticated'}" 
                                     FontSize="11" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Monitoring Status -->
                        <StackPanel Grid.Row="1" 
                                  Orientation="Horizontal" 
                                  Margin="0,0,0,5">
                            <Ellipse Style="{StaticResource StatusIndicatorStyle}"
                                   Fill="{Binding IsMonitoring, Converter={StaticResource BoolToStatusColorConverter}, FallbackValue=Red}"/>
                            <TextBlock Text="{Binding MonitoringStatus, FallbackValue='Monitoring Stopped'}" 
                                     FontSize="11" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Enforcement Status -->
                        <StackPanel Grid.Row="2" 
                                  Orientation="Horizontal">
                            <Ellipse Style="{StaticResource StatusIndicatorStyle}"
                                   Fill="{Binding IsEnforcementActive, Converter={StaticResource BoolToStatusColorConverter}, FallbackValue=Red}"/>
                            <TextBlock Text="{Binding EnforcementStatus, FallbackValue='Enforcement Disabled'}" 
                                     FontSize="11" 
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Toolbar -->
            <Border Grid.Row="0" 
                    Background="White" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="0,0,0,1"
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentViewTitle, FallbackValue='Dashboard'}" 
                                 FontSize="18" 
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentViewSubtitle}" 
                                 FontSize="12" 
                                 Foreground="#666"
                                 VerticalAlignment="Center"
                                 Margin="15,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🔄 Refresh" 
                                Command="{Binding RefreshCommand}"
                                Padding="12,6"
                                Margin="5,0"/>
                        <Button Content="⚠️ Emergency Stop" 
                                Command="{Binding EmergencyStopCommand}"
                                Background="#F44336"
                                Foreground="White"
                                Padding="12,6"
                                Margin="5,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Content Frame -->
            <Frame Grid.Row="1" 
                   x:Name="ContentFrame"
                   NavigationUIVisibility="Hidden"
                   Background="White"
                   Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>